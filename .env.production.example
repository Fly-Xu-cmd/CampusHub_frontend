# 生产环境变量配置示例
# 复制此文件为 .env.production 并填写实际值

# API 基础 URL (必填)
VITE_BASE_URL=https://api.yourdomain.com
VITE_PROD_BASE_URL=https://api.yourdomain.com

# WebSocket URL (必填)
VITE_WS_URL=wss://ws.yourdomain.com/ws

# ============================================
# K8s 后端配置说明
# ============================================
# 后端使用 K8s 部署，前端容器在同一内网 (192.168.10.9)
# 前端可直接访问后端，无需 Nginx 代理
# 访问方式：
#   1. K8s Service 内部 DNS: http://backend-api.default.svc.cluster.local
#   2. K8s 集群外部 IP: http://192.168.10.9:8888
#   3. K8s NodePort: http://192.168.10.9:8888
#
# 如果需要 Nginx 代理后端 API，请取消注释以下三行：
# VITE_BASE_URL=http://192.168.10.9:8888
# VITE_PROD_BASE_URL=http://192.168.10.9:8888
# VITE_WS_URL=ws://192.168.10.9:8888/ws

# ============================================
# 应用信息
# ============================================
VITE_APP_NAME=CampusHub
VITE_APP_VERSION=1.0.0

# 是否开启调试模式 (生产环境设置为 false)
VITE_DEBUG=false

# 极验验证码 ID (必填)
VITE_GEETEST_ID=your_geetest_captcha_id
